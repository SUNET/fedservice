{
  "logging": {
    "version": 1,
    "disable_existing_loggers": false,
    "root": {
      "handlers": [
        "default"
      ],
      "level": "DEBUG"
    },
    "loggers": {
      "idp": {
        "level": "DEBUG"
      }
    },
    "handlers": {
      "default": {
        "class": "logging.FileHandler",
        "filename": "relying_party_automatic/debug.log",
        "formatter": "default"
      }
    },
    "formatters": {
      "default": {
        "format": "%(asctime)s %(name)s %(levelname)s %(message)s"
      }
    }
  },
  "entity": {
    "entity_id": "https://127.0.0.1:4015",
    "entity_type": {
      "federation_entity": {
        "httpc_params": {
          "verify": false
        },
        "key_config": {
          "private_path": "relying_party_automatic/private/fed_keys.json",
          "key_defs": [
            {
              "type": "RSA",
              "key": "",
              "use": [
                "sig"
              ]
            },
            {
              "type": "EC",
              "crv": "P-256",
              "use": [
                "sig"
              ]
            }
          ],
          "public_path": "relying_party_automatic/static/fed_keys.json",
          "read_only": false
        },
        "authority_hints": {
          "class": "idpyoidc.storage.listfile.ReadOnlyListFile",
          "kwargs": {
            "file_name": "relying_party_automatic/authority_hints"
          }
        },
        "trust_anchors": {
          "class": "idpyoidc.storage.abfile_no_cache.AbstractFileSystemNoCache",
          "kwargs": {
            "fdir": "relying_party_automatic/trust_anchors",
            "key_conv": "idpyoidc.util.Base64",
            "value_conv": "idpyoidc.util.JSON"
          }
        },
        "trust_marks": {
          "class": "idpyoidc.storage.listfile.ReadOnlyListFile",
          "kwargs": {
            "file_name": "relying_party_automatic/trust_marks"
          }
        },
        "endpoint": [
          "entity_configuration"
        ],
        "services": [
          "entity_configuration",
          "entity_statement",
          "list"
        ]
      },
      "openid_relying_party": {
        "class": "fedservice.appclient.ClientEntity",
        "kwargs": {
          "config": {
            "client_class": "fedservice.appclient.ClientEntity",
            "base_url": "https://127.0.0.1:4015",
            "entity_id": "https://127.0.0.1:4015",
            "client_type": "oidc",
            "entity_type": "openid_relying_party",
            "httpc_params": {
              "verify": false
            },
            "key_conf": {
              "private_path": "private/expl.rp.jwks.json",
              "key_defs": [
                {
                  "type": "RSA",
                  "use": [
                    "sig"
                  ]
                },
                {
                  "type": "EC",
                  "crv": "P-256",
                  "use": [
                    "sig"
                  ]
                }
              ],
              "public_path": "relying_party_automatic/static/rp_keys.json",
              "read_only": false
            },
            "preference": {
              "application_name": "rphandler",
              "application_type": "web",
              "contacts": [
                "ops@example.com"
              ],
              "response_types_supported": [
                "code"
              ],
              "scope": [
                "openid",
                "profile",
                "email",
                "address",
                "phone"
              ],
              "token_endpoint_auth_method": [
                "private_key_jwt"
              ],
              "client_registration_types": [
                "automatic"
              ]
            },
            "services": {
              "authorization": {
                "class": "fedservice.appclient.oidc.authorization.Authorization",
                "kwargs": {}
              },
              "accesstoken": {
                "class": "idpyoidc.client.oidc.access_token.AccessToken",
                "kwargs": {}
              },
              "userinfo": {
                "class": "idpyoidc.client.oidc.userinfo.UserInfo",
                "kwargs": {}
              }
            }
          }
        }
      }
    }
  },
  "webserver": {
    "port": 4015,
    "server_cert": "certs/cert.pem",
    "server_key": "certs/key.pem",
    "domain": "0.0.0.0"
  }
}
